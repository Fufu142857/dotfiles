#!/opt/homebrew/bin/python3.9
import json
import os
import re
import subprocess
import sys
import urllib.request
from html.parser import HTMLParser


class OxfordParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.result = ""
        self.stack = []

        self.C_MAIN = "\033[1;36m"
        self.C_EX_EN = "\033[38;5;246m"
        self.C_EX_ZH = "\033[38;5;252m"
        self.C_POS = "\033[1;35m"
        self.C_NUM = "\033[1;33m"
        self.C_CTX = "\033[38;5;240m"
        self.RESET = "\033[0m"

    def handle_starttag(self, tag, attrs):
        classes = dict(attrs).get("class", "").split()
        self.stack.append((tag, classes))

        if any(c in ["ty_pinyin", "hwg"] for c in classes):
            return

        in_exg = any(any(x in c for x in ["exg", "idg", "phrg"]) for _, c in self.stack)

        if any(x in classes for x in ["ex", "id", "con"]):
            self.result += f"\n      {self.C_EX_EN}▸ "
        elif "trans" in classes:
            if in_exg:
                self.result += f"\n        {self.C_EX_ZH}"
            else:
                self.result += f" {self.C_MAIN}"
        elif "ps" in classes:
            self.result += f"\n  {self.C_POS}"
        elif "ty_label" in classes:
            self.result += f"\n\n    {self.C_NUM}"
        elif any(
            c in classes
            for c in [
                "ind",
                "fld",
                "co",
                "gp",
                "lev",
                "frm",
                "gl",
                "frmg",
                "gr",
                "reg",
                "cnt",
            ]
        ):
            self.result += f" {self.C_CTX}"

    def handle_data(self, data):
        if any("ty_pinyin" in c or "hwg" in c for _, c in self.stack):
            return

        if self.stack and "ty_label" in self.stack[-1][1]:
            num = data.strip(" .")
            mapping = {
                "1": "①",
                "2": "②",
                "3": "③",
                "4": "④",
                "5": "⑤",
                "6": "⑥",
                "7": "⑦",
                "8": "⑧",
                "9": "⑨",
            }
            data = mapping.get(num, f" {num}. ")

        self.result += data

    def handle_endtag(self, tag):
        if not self.stack:
            return
        _, classes = self.stack.pop()

        color_trigger_classes = [
            "ex",
            "trans",
            "ps",
            "ty_label",
            "ind",
            "fld",
            "co",
            "id",
            "gp",
            "con",
            "lev",
            "frm",
            "gl",
            "frmg",
            "gr",
            "reg",
            "cnt",
        ]

        if any(x in classes for x in color_trigger_classes):
            current_color = self.RESET
            in_exg = any(
                any(x in c for x in ["exg", "idg", "phrg"]) for _, c in self.stack
            )

            for _, cls in self.stack:
                if any(x in cls for x in ["ex", "id", "con"]):
                    current_color = self.C_EX_EN
                elif "trans" in cls:
                    current_color = self.C_EX_ZH if in_exg else self.C_MAIN
                elif "ps" in cls:
                    current_color = self.C_POS
                elif "ty_label" in cls:
                    current_color = self.C_NUM
                elif any(
                    c in cls
                    for c in [
                        "ind",
                        "fld",
                        "co",
                        "gp",
                        "lev",
                        "frm",
                        "gl",
                        "frmg",
                        "gr",
                        "reg",
                        "cnt",
                    ]
                ):
                    current_color = self.C_CTX

            self.result += current_color


def is_chinese(text):
    return bool(re.search(r"[\u4e00-\u9fff]", text))


def fallback_to_ollama(text):
    # Set proxy bypass for localhost
    os.environ["NO_PROXY"] = "localhost,127.0.0.1,::1"
    os.environ["no_proxy"] = "localhost,127.0.0.1,::1"

    if is_chinese(text):
        sys_prompt = "Translate the following Chinese text to English. Output ONLY the translation without any explanations, original text repetition, or quotation marks. Text:"
    else:
        sys_prompt = "Translate the following English text to natural and fluent Chinese. You must translate completely without leaving any English words in the output. Output ONLY the translation without any explanations, original text repetition, or quotation marks. Text:"

    prompt = f"{sys_prompt}\n\n{text}"

    try:
        # Use HTTP API directly for lowest overhead
        req = urllib.request.Request(
            "http://localhost:11434/api/generate",
            data=json.dumps(
                {"model": "dict7b", "prompt": prompt, "stream": False}
            ).encode("utf-8"),
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req) as response:
            result = json.loads(response.read().decode("utf-8"))
            print(
                f"\n\033[1;36m[AI Translation]\033[0m\n{result.get('response', '').strip()}\n"
            )
            return True
    except Exception as e:
        # Fallback to CLI if HTTP fails
        try:
            result = subprocess.run(
                ["ollama", "run", "dict7b", prompt],
                capture_output=True,
                text=True,
                check=True,
            )
            print(f"\n\033[1;36m[AI Translation]\033[0m\n{result.stdout.strip()}\n")
            return True
        except Exception as cli_e:
            print(
                f"\n\033[1;31m[ AI Fallback Failed ]\033[0m\nCould not reach Ollama: {cli_e}"
            )
            return False


def lookup(word):
    file_path = os.path.expanduser(
        # Because I am lazy so I just write it like that.
        "~/Downloads/42093-main/词典刺客/牛津英汉汉英词典/mdx/牛津英汉汉英词典.txt"
    )

    # Strip common comment symbols (//, #, /*, *, <!--, etc.) from the beginning and end
    clean_word = re.sub(
        r"^(?:\s*//\s*|\s*#\s*|\s*/\*\s*|\s*\*\s*|\s*<!--\s*)", "", word
    )
    clean_word = re.sub(r"(?:\s*\*/\s*|\s*-->\s*)$", "", clean_word)

    search_word = clean_word.strip().lower()

    # Heuristic: If the input is extremely long (> 40 characters), it is definitely a sentence/paragraph,
    # so we bypass the local dictionary to save the 180ms full-scan overhead and go straight to AI.
    if len(search_word) > 40:
        fallback_to_ollama(clean_word)
        return

    try:
        found = False
        with open(file_path, "r", encoding="utf-8") as f:
            while True:
                line = f.readline()
                if not line:
                    break

                if line.strip().lower() == search_word:
                    html_content = f.readline()

                    pr_match = re.search(
                        r'class="[^"]*ph[^"]*"[^>]*>([^<]+)<', html_content
                    )
                    pron_text = pr_match.group(1).strip() if pr_match else ""
                    pron_display = (
                        f" | \033[38;5;245m/{pron_text}/\033[0m |" if pron_text else ""
                    )

                    tg_hw_match = re.search(
                        r'class="[^"]*(?:ty_hom|hom|hg|tg_hw)[^"]*"[^>]*>\s*(\d+)\s*<',
                        html_content[:600],
                    )
                    if not tg_hw_match:
                        tg_hw_match = re.search(
                            r"<(?:sup|tg_hw|hom)[^>]*>\s*(\d+)\s*</", html_content[:600]
                        )

                    sup_map = {
                        "1": "¹",
                        "2": "²",
                        "3": "³",
                        "4": "⁴",
                        "5": "⁵",
                        "6": "⁶",
                        "7": "⁷",
                        "8": "⁸",
                        "9": "⁹",
                    }
                    sup_num = (
                        sup_map.get(tg_hw_match.group(1), "") if tg_hw_match else ""
                    )

                    parser = OxfordParser()
                    parser.feed(html_content)
                    text = parser.result

                    text = re.sub(
                        r"\b([A-Z])\.(?=\s)", rf"\n\n\033[1;35m\1.\033[0m", text
                    )

                    lines = text.split("\n")
                    cleaned_lines = []
                    prev_empty = True

                    for l in lines:
                        real_text = re.sub(r"\x1b\[[0-9;]*m", "", l).strip()
                        if not real_text:
                            if not prev_empty:
                                cleaned_lines.append("")
                                prev_empty = True
                            continue

                        prev_empty = False
                        leading_space = len(l) - len(l.lstrip(" "))
                        rest = l.lstrip(" ")

                        last_rest = ""
                        while rest != last_rest:
                            last_rest = rest
                            rest = re.sub(r" (\x1b\[[0-9;]*m)", r"\1 ", rest)
                        rest = re.sub(r" +", " ", rest)

                        rest = re.sub(
                            r"([\(\[<（［‹«])((?:\x1b\[[0-9;]*m)*)\s+", r"\1\2", rest
                        )
                        rest = re.sub(
                            r"\s+((?:\x1b\[[0-9;]*m)*)([\)\]>）］›»])", r"\1\2", rest
                        )
                        rest = re.sub(r"\s+((?:\x1b\[[0-9;]*m)*)([,，])", r"\1\2", rest)

                        cleaned_lines.append(" " * leading_space + rest.strip())

                    text = "\n".join(cleaned_lines)
                    text = re.sub(r"\n{3,}", "\n\n", text)

                    print(f"\n\033[1;37m{line.strip()}{sup_num}\033[0m{pron_display}")
                    print(text.strip("\n") + "\n")
                    found = True

        if not found:
            # Word not found in Oxford dictionary, fallback to AI
            fallback_to_ollama(clean_word)

    except FileNotFoundError:
        print("Error: Not Found Dict")
        fallback_to_ollama(clean_word)


def interactive_mode():
    print("✨ Interactive Translation Session ✨")
    print("Type ':q' or ':quit' to exit.")

    # Import readline for history support in Python interactive mode
    try:
        import readline
    except ImportError:
        pass

    while True:
        try:
            user_input = input("\n> ").strip()
            if user_input in [":q", ":quit"]:
                break
            if not user_input:
                continue
            lookup(user_input)
        except (KeyboardInterrupt, EOFError):
            break


if __name__ == "__main__":
    if len(sys.argv) > 1:
        if sys.argv[1] == "-I":
            interactive_mode()
        else:
            lookup(" ".join(sys.argv[1:]))
    else:
        print("Usage:")
        print(
            "  trans <text>        Translate the specified word or sentence directly."
        )
        print("  trans -I            Start an interactive translation session.")
        print("\nDescription:")
        print(
            "  Unified translation interface (Pure Python). Automatically queries the"
        )
        print("  local Oxford dictionary for exact word matches. Seamlessly falls back")
        print("  to the local LLM (dict7b) via HTTP API for sentences, phrases, or")
        print("  unknown words.")
